<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  
  <object class="AdwApplicationWindow" id="main_window">
    <property name="default-width">1100</property>
    <property name="default-height">750</property>
    
    <property name="content">
      <object class="AdwNavigationSplitView">
        
        <!-- 1. الشريط الجانبي (المستندات والتنقل) -->
        <child type="sidebar">
          <object class="AdwNavigationPage">
            <property name="title">Navigation</property>
            <property name="child">
              <object class="GtkBox" id="sidebar_box">
                <property name="orientation">vertical</property>
                <property name="width-request">64</property>
                <style class="navigation-sidebar"/>
                
                <!-- شعار التطبيق (الحرف Q) -->
                <child>
                  <object class="GtkBox">
                    <property name="margin-top">16</property>
                    <property name="margin-bottom">48</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Q</property>
                        <style class="title-1"/>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- أزرار التنقل المنتصفية -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">24</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkButton" id="button_editor">
                        <property name="icon-name">document-edit-symbolic</property>
                        <style class="circular"/>
                        <style class="suggested-action"/> <!-- هذا سيأخذ اللون الوردي لاحقاً -->
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="button_files">
                        <property name="icon-name">folder-symbolic</property>
                        <style class="flat"/>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- أزرار الإعدادات أسفل الشريط -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">24</property>
                    <property name="margin-bottom">24</property>
                    <property name="valign">end</property>
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkButton" id="button_settings">
                        <property name="icon-name">emblem-system-symbolic</property>
                        <style class="flat"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="button_stats">
                        <property name="icon-name">dialog-information-symbolic</property>
                        <style class="flat"/>
                      </object>
                    </child>
                  </object>
                </child>
                
              </object>
            </property>
          </object>
        </child>

        <!-- 2. مساحة الكتابة والعمل الرئيسية -->
        <child type="content">
          <object class="AdwNavigationPage">
            <property name="title">Workspace</property>
            <property name="child">
              <object class="GtkBox" id="workspace_box">
                <property name="orientation">vertical</property>
                
                <!-- شريط العنوان النظيف العلوي -->
                <child>
                  <object class="AdwHeaderBar">
                    <property name="title-widget">
                       <object class="AdwWindowTitle">
                        <property name="title">~/Documents/Economics_Notes.md</property>
                      </object>
                    </property>
                    <!-- زر القائمة المنبثقة للثيمات -->
                    <child type="end">
                       <object class="GtkMenuButton">
                        <property name="icon-name">open-menu-symbolic</property>
                        <property name="popover">
                          <object class="GtkPopover">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="margin-start">10</property>
                                <property name="margin-end">10</property>
                                <property name="margin-top">10</property>
                                <property name="margin-bottom">10</property>
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkButton" id="theme_dark">
                                    <property name="label">Adwaita Dark</property>
                                    <style class="flat"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="theme_sepia">
                                    <property name="label">Classic Sepia</property>
                                    <style class="flat"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="theme_midnight">
                                    <property name="label">Midnight Writer</property>
                                    <style class="flat"/>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="export_pdf">
                                    <property name="label">تصدير كـ PDF</property>
                                    <style class="flat"/>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- الحاوية الذكية لحصر عرض النص في 800 بكسل -->
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">800</property>
                    <property name="vexpand">true</property>
                    
                    <property name="child">
                      <object class="GtkScrolledWindow" id="editor_scroll">
                        <property name="hscrollbar-policy">never</property>
                        <property name="vscrollbar-policy">automatic</property>
                        
                        <property name="child">
                          <object class="GtkTextView" id="main_text_view">
                            <property name="monospace">true</property>
                            <property name="wrap-mode">word</property> <!-- تفعيل التفاف الكلمات -->
                            <property name="left-margin">24</property> <!-- الهوامش المطلوبة -->
                            <property name="right-margin">24</property>
                            <property name="top-margin">24</property>
                            <property name="bottom-margin">300</property> <!-- تأثير الـ Overscroll المريح للعين -->
                          </object>
                        </property>
                      </object>
                    </property>
                  </object>
                </child>
                
              </object>
            </property>
          </object>
        </child>
        
      </object>
    </property>
  </object>
</interface>
