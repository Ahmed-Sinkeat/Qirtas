<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="lawh-midnight" _name="Lawh Midnight" version="1.0">
  <author>Lawh Team</author>
  <description>Custom midnight style scheme for Lawh Markdown Editor</description>

  <!-- Colors -->
  <color name="pink" value="#ff79c6"/>
  <color name="cyan" value="#8be9fd"/>
  <color name="gray" value="#6272a4"/>
  <color name="white" value="#ffffff"/>
  <color name="bg" value="#000000"/>
  <color name="search-bg" value="#ff79c6"/>
  <color name="h1" value="#ff79c6"/>
  <color name="h2" value="#00ffcc"/>
  <color name="h3" value="#50fa7b"/>
  <color name="h4" value="#ffb86c"/>
  <color name="h5" value="#bd93f9"/>
  <color name="h6" value="#ff5555"/>

  <style name="text" foreground="white" background="bg"/>
  <style name="search-match" background="search-bg" foreground="bg"/>
  
  <!-- Markdown Styles -->
  <style name="markdown:header" foreground="pink" bold="true"/>
  <style name="markdown:h1" foreground="h1" bold="true"/>
  <style name="markdown:h2" foreground="h2" bold="true"/>
  <style name="markdown:h3" foreground="h3" bold="true"/>
  <style name="markdown:h4" foreground="h4" bold="true"/>
  <style name="markdown:h5" foreground="h5" bold="true"/>
  <style name="markdown:h6" foreground="h6" bold="true"/>
  <style name="markdown:link-text" foreground="cyan"/>
  <style name="markdown:url" foreground="cyan" italic="true"/>
  <style name="markdown:blockquote-line" foreground="gray"/>
  <style name="markdown:list-marker" foreground="pink"/>
  
  <style name="def:heading" foreground="pink" bold="true"/>
  <style name="def:comment" foreground="gray"/>
  <style name="def:string" foreground="cyan"/>
  <style name="def:net-address" foreground="cyan"/>
  
  <style name="current-line" background="bg"/>
  <style name="line-numbers" foreground="gray" background="bg"/>
  <style name="current-line-number" foreground="pink" bold="true"/>

  <style name="lawh_markdown:string" foreground="#4682B4"/>
  <style name="lawh_markdown:bold" foreground="#ffffff" bold="true"/>
  <style name="markdown:bold" foreground="#ffffff" bold="true"/>
  <style name="markdown:italic" italic="true"/>
  <style name="lawh_markdown:wiki-link" foreground="#00E5FF" underline="true"/>
</style-scheme>
