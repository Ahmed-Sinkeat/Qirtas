<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="lawh-sepia" _name="Lawh Sepia" version="1.0">
  <author>Lawh Team</author>
  <description>Custom sepia style scheme for Lawh Markdown Editor</description>

  <!-- Colors -->
  <color name="purple" value="#a42e79"/>
  <color name="teal" value="#2aa198"/>
  <color name="brown" value="#586e75"/>
  <color name="dark" value="#073642"/>
  <color name="bg" value="#fdf6e3"/>
  <color name="search-bg" value="#2aa198"/>
  <color name="h1" value="#b58900"/>
  <color name="h2" value="#cb4b16"/>
  <color name="h3" value="#dc322f"/>
  <color name="h4" value="#a42e79"/>
  <color name="h5" value="#268bd2"/>
  <color name="h6" value="#859900"/>

  <style name="text" foreground="dark" background="bg"/>
  <style name="search-match" background="search-bg" foreground="bg"/>
  
  <!-- Markdown Styles -->
  <style name="markdown:header" foreground="purple" bold="true"/>
  <style name="markdown:h1" foreground="h1" bold="true"/>
  <style name="markdown:h2" foreground="h2" bold="true"/>
  <style name="markdown:h3" foreground="h3" bold="true"/>
  <style name="markdown:h4" foreground="h4" bold="true"/>
  <style name="markdown:h5" foreground="h5" bold="true"/>
  <style name="markdown:h6" foreground="h6" bold="true"/>
  <style name="markdown:link-text" foreground="teal"/>
  <style name="markdown:url" foreground="teal" italic="true"/>
  <style name="markdown:blockquote-line" foreground="brown"/>
  <style name="markdown:list-marker" foreground="purple"/>
  
  <style name="def:heading" foreground="purple" bold="true"/>
  <style name="def:comment" foreground="brown"/>
  <style name="def:string" foreground="teal"/>
  <style name="def:net-address" foreground="teal"/>
  
  <style name="current-line" background="bg"/>
  <style name="line-numbers" foreground="brown" background="bg"/>
  <style name="current-line-number" foreground="purple" bold="true"/>

  <style name="lawh_markdown:string" foreground="#4682B4"/>
  <style name="lawh_markdown:bold" foreground="#073642" bold="true"/>
  <style name="markdown:bold" foreground="#073642" bold="true"/>
  <style name="markdown:italic" italic="true"/>
  <style name="lawh_markdown:wiki-link" foreground="#2aa198" underline="true"/>
</style-scheme>
