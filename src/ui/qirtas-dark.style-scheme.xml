<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="qirtas-dark" _name="Qirtas Dark" version="1.0">
  <author>Qirtas Team</author>
  <description>Custom dark style scheme for Qirtas Markdown Editor</description>

  <!-- ── Palette ── -->
  <color name="pink"       value="#cdd8f1"/>
  <color name="cyan"       value="#8fb4d9"/>
  <color name="gray"       value="#6f789a"/>
  <color name="white"      value="#e9ecf5"/>
  <color name="bg"         value="#0c1330"/>
  <color name="bg-line"    value="#cdd8f10d"/>
  <color name="search-bg"  value="#cdd8f1"/>
  <color name="h1"         value="#cdd8f1"/>
  <color name="h2"         value="#bccdf0"/>
  <color name="h3"         value="#a8bce8"/>
  <color name="h4"         value="#d6c39a"/>
  <color name="h5"         value="#9aaedd"/>
  <color name="h6"         value="#8e9ec9"/>
  <color name="orange"     value="#d6c39a"/>
  <color name="green"      value="#a8bce8"/>
  <color name="purple"     value="#9aaedd"/>
  <color name="yellow"     value="#e8dba8"/>
  <color name="comment-fg" value="#5c6587"/>
  <color name="gold"       value="#c2a878"/>
  <color name="calm-purple" value="#aebde8"/>

  <!-- ── Editor base ── -->
  <style name="text"               foreground="white"     background="bg"/>
  <style name="selection"          background="#1b2750"/>
  <style name="current-line"       background="bg-line"/>
  <style name="line-numbers"       foreground="gray"      background="bg"/>
  <style name="current-line-number" foreground="pink"     bold="true"/>
  <style name="search-match"       background="search-bg" foreground="bg"/>
  <style name="bracket-match"      foreground="yellow"    bold="true"/>

  <!-- ── def: base styles (used as fallback) ── -->
  <style name="def:heading"              foreground="pink"   bold="true"/>
  <style name="def:emphasis"             italic="true"/>
  <style name="def:strong-emphasis"      foreground="white"  bold="true"/>
  <style name="def:inline-code"          foreground="cyan"/>
  <style name="def:preformatted-section" foreground="cyan"/>
  <style name="def:comment"             foreground="comment-fg" italic="true"/>
  <style name="def:string"              foreground="cyan"/>
  <style name="def:net-address"         foreground="cyan"   underline="true"/>
  <style name="def:link-destination"    foreground="cyan"   underline="true"/>
  <style name="def:link-text"           foreground="cyan"/>
  <style name="def:list-marker"         foreground="pink"/>
  <style name="def:note"                foreground="orange"/>
  <style name="def:shebang"             foreground="gray"   italic="true"/>
  <style name="def:special-char"        foreground="purple"/>

  <!-- ── Headings by level (qirtas_markdown: prefix → our lang file) ── -->
  <style name="qirtas_markdown:h1"         foreground="h1"    bold="true" weight="bold" scale="1.5"/>
  <style name="qirtas_markdown:h2"         foreground="h2"    bold="true" weight="bold" scale="1.3"/>
  <style name="qirtas_markdown:h3"         foreground="h3"    bold="true" weight="bold" scale="1.15"/>
  <style name="qirtas_markdown:h4"         foreground="h4"    bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h5"         foreground="h5"    bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h6"         foreground="h6"    bold="true" weight="bold" scale="1.0"/>

  <!-- ── Inline formatting ── -->
  <style name="qirtas_markdown:bold"        foreground="gold"  bold="true" weight="bold"/>
  <style name="qirtas_markdown:italic"      foreground="calm-purple" italic="true"/>
  <style name="qirtas_markdown:bold-italic" foreground="gold"  bold="true" weight="bold" italic="true"/>
  <style name="qirtas_markdown:strikethrough" strikethrough="true" foreground="gray"/>
  <style name="qirtas_markdown:inline-code" foreground="cyan"   background="#1e2230"/>

  <!-- ── Block elements ── -->
  <style name="qirtas_markdown:blockquote"  foreground="gray"   italic="true"/>
  <style name="qirtas_markdown:list-marker" foreground="pink"/>

  <!-- ── Links ── -->
  <style name="qirtas_markdown:link-text"   foreground="cyan"/>
  <style name="qirtas_markdown:url"         foreground="cyan"   underline="true" italic="true"/>
  <style name="qirtas_markdown:wiki-link"   foreground="#00E5FF" underline="true"/>

  <!-- ── Special ── -->
  <style name="qirtas_markdown:highlight"   background="#d6c39a" foreground="#0c1330"/>
  <style name="qirtas_markdown:math"        foreground="green"/>
  <style name="qirtas_markdown:comment"     foreground="comment-fg" italic="true"/>

  <!-- ── Compatibility aliases for system markdown.lang (v4) ── -->
  <style name="markdown:header"           foreground="pink"   bold="true"/>
  <style name="markdown:h1"              foreground="h1"    bold="true"  scale="1.5"/>
  <style name="markdown:h2"              foreground="h2"    bold="true"  scale="1.3"/>
  <style name="markdown:h3"              foreground="h3"    bold="true"/>
  <style name="markdown:h4"              foreground="h4"    bold="true"/>
  <style name="markdown:h5"              foreground="h5"    bold="true"/>
  <style name="markdown:h6"              foreground="h6"    bold="true"/>
  <style name="markdown:bold"            foreground="white"  bold="true"/>
  <style name="markdown:italic"          italic="true"/>
  <style name="markdown:strikethrough"   strikethrough="true" foreground="gray"/>
  <style name="markdown:inline-code"     foreground="cyan"/>
  <style name="markdown:code"            foreground="cyan"   background="#1e2230"/>
  <style name="markdown:link-text"       foreground="cyan"/>
  <style name="markdown:url"             foreground="cyan"   underline="true"/>
  <style name="markdown:blockquote-line" foreground="gray"   italic="true"/>
  <style name="markdown:list-marker"     foreground="pink"/>
</style-scheme>
