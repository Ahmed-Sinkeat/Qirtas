<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="qirtas-navy" _name="Paper &amp; Ink Navy" version="1.0">
  <author>Qirtas Team</author>
  <description>Paper &amp; Ink Navy style scheme (pure-white paper, app-icon navy ink)</description>

  <!-- ── Palette ── -->
  <color name="ink"        value="#33302a"/>
  <color name="ink-muted"  value="#76705f"/>
  <color name="ink-faint"  value="#a59d88"/>
  <color name="bg"         value="#ffffff"/>
  <color name="bg-line"    value="#f5f2ea"/>
  <color name="selection"  value="#dfe6f1"/>
  <color name="navy"       value="#213a63"/>

  <!-- ── Editor base ── -->
  <style name="text"               foreground="ink"     background="bg"/>
  <style name="selection"          background="selection"/>
  <style name="current-line"       background="bg-line"/>
  <style name="line-numbers"       foreground="ink-faint" background="bg"/>
  <style name="current-line-number" foreground="navy"     bold="true"/>
  <style name="search-match"       background="navy"     foreground="bg"/>
  <style name="bracket-match"      foreground="navy"    bold="true"/>

  <!-- ── def: base styles ── -->
  <style name="def:heading"              foreground="navy"  bold="true"/>
  <style name="def:emphasis"             italic="true"/>
  <style name="def:strong-emphasis"      foreground="navy" bold="true"/>
  <style name="def:inline-code"          foreground="ink-muted"/>
  <style name="def:preformatted-section" foreground="ink-muted"/>
  <style name="def:comment"             foreground="ink-faint" italic="true"/>
  <style name="def:string"              foreground="ink-muted"/>
  <style name="def:net-address"         foreground="navy"   underline="true"/>
  <style name="def:link-destination"    foreground="navy"   underline="true"/>
  <style name="def:link-text"           foreground="ink"/>
  <style name="def:list-marker"         foreground="ink-muted"/>
  <style name="def:shebang"             foreground="ink-faint"   italic="true"/>
  <style name="def:special-char"        foreground="navy"/>
  <style name="def:note"                foreground="navy"           bold="true"/>

  <!-- ── Headings by level ── -->
  <style name="qirtas_markdown:h1"         foreground="navy"   bold="true" weight="bold" scale="1.5"/>
  <style name="qirtas_markdown:h2"         foreground="navy"   bold="true" weight="bold" scale="1.3"/>
  <style name="qirtas_markdown:h3"         foreground="navy"   bold="true" weight="bold" scale="1.15"/>
  <style name="qirtas_markdown:h4"         foreground="navy"   bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h5"         foreground="navy"   bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h6"         foreground="navy"   bold="true" weight="bold" scale="1.0"/>

  <!-- ── Inline formatting ── -->
  <style name="qirtas_markdown:bold"        foreground="navy" bold="true" weight="bold"/>
  <style name="qirtas_markdown:italic"      foreground="ink"   italic="true"/>
  <style name="qirtas_markdown:bold-italic" foreground="navy"  bold="true" weight="bold" italic="true"/>
  <style name="qirtas_markdown:strikethrough" strikethrough="true" foreground="ink-faint"/>
  <style name="qirtas_markdown:inline-code" foreground="ink-muted"   background="selection"/>

  <!-- ── Block elements ── quote = muted teal ink + faint tint, distinct
       from the navy accent. -->
  <style name="qirtas_markdown:blockquote"  foreground="#3f6b5a" background="#eaf2ee" italic="true"/>
  <style name="def:blockquote"              foreground="#3f6b5a" background="#eaf2ee" italic="true"/>
  <style name="markdown:blockquote-line"    foreground="#3f6b5a" background="#eaf2ee" italic="true"/>
  <style name="qirtas_markdown:list-marker" foreground="ink-muted"/>

  <!-- ── Links ── -->
  <style name="qirtas_markdown:link-text"   foreground="ink"/>
  <style name="qirtas_markdown:url"         foreground="navy"   underline="true" italic="true"/>
  <style name="qirtas_markdown:wiki-link"   foreground="navy" underline="true"/>

  <!-- ── Special ── -->
  <style name="qirtas_markdown:highlight"   background="selection" foreground="navy"/>
  <style name="qirtas_markdown:math"        foreground="ink-muted"/>
  <style name="qirtas_markdown:comment"     foreground="ink-faint" italic="true"/>

  <!-- ── Compatibility aliases ── -->
  <style name="markdown:header"           foreground="navy"   bold="true"/>
  <style name="markdown:h1"              foreground="navy"    bold="true"  scale="1.5"/>
  <style name="markdown:h2"              foreground="navy"    bold="true"  scale="1.3"/>
  <style name="markdown:h3"              foreground="navy"    bold="true"/>
  <style name="markdown:h4"              foreground="navy"    bold="true"/>
  <style name="markdown:h5"              foreground="navy"    bold="true"/>
  <style name="markdown:h6"              foreground="navy"    bold="true"/>
  <style name="markdown:bold"            foreground="navy"  bold="true"/>
  <style name="markdown:italic"          italic="true"/>
  <style name="markdown:strikethrough"   strikethrough="true" foreground="ink-faint"/>
  <style name="markdown:inline-code"     foreground="ink-muted"/>
  <style name="markdown:code"            foreground="ink-muted"   background="selection"/>
  <style name="markdown:link-text"       foreground="ink"/>
  <style name="markdown:url"             foreground="navy"   underline="true"/>
  <style name="markdown:blockquote-line" foreground="ink-muted"   italic="true"/>
  <style name="markdown:list-marker"     foreground="ink-muted"/>
</style-scheme>
