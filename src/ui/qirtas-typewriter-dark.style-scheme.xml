<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="qirtas-typewriter-dark" _name="Qirtas Typewriter Dark" version="1.0">
  <author>Qirtas Team</author>
  <description>Typewriter Dark style scheme for Qirtas Markdown Editor</description>

  <!-- ── Palette ── -->
  <color name="red"        value="#ff4d4d"/>
  <color name="blue"       value="#3ea6ff"/>
  <color name="green"      value="#81c784"/>
  <color name="bg"         value="#121212"/>
  <color name="bg-line"    value="#1f1f1f"/>
  <color name="text"       value="#e0e0e0"/>
  <color name="text-dim"   value="#aaaaaa"/>
  <color name="text-muted" value="#666666"/>

  <!-- ── Editor base ── -->
  <style name="text"               foreground="text"     background="bg"/>
  <style name="selection"          background="#1f1f1f"/>
  <style name="current-line"       background="bg-line"/>
  <style name="line-numbers"       foreground="text-muted" background="bg"/>
  <style name="current-line-number" foreground="red"      bold="true"/>
  <style name="search-match"       background="red"      foreground="bg"/>
  <style name="bracket-match"      foreground="blue"     bold="true"/>

  <!-- ── def: base styles ── -->
  <style name="def:heading"              foreground="red"   bold="true"/>
  <style name="def:emphasis"             italic="true"/>
  <style name="def:strong-emphasis"      foreground="text"  bold="true"/>
  <style name="def:inline-code"          foreground="green"/>
  <style name="def:preformatted-section" foreground="green"/>
  <style name="def:comment"             foreground="text-muted" italic="true"/>
  <style name="def:string"              foreground="green"/>
  <style name="def:net-address"         foreground="blue"   underline="true"/>
  <style name="def:link-destination"    foreground="blue"   underline="true"/>
  <style name="def:link-text"           foreground="blue"/>
  <style name="def:list-marker"         foreground="red"/>
  <style name="def:shebang"             foreground="text-muted"   italic="true"/>
  <style name="def:special-char"        foreground="red"/>
  <style name="def:note"                foreground="red"            bold="true"/>

  <!-- ── Headings by level ── -->
  <style name="qirtas_markdown:h1"         foreground="red"    bold="true" weight="bold" scale="1.5"/>
  <style name="qirtas_markdown:h2"         foreground="text"   bold="true" weight="bold" scale="1.3"/>
  <style name="qirtas_markdown:h3"         foreground="text"   bold="true" weight="bold" scale="1.15"/>
  <style name="qirtas_markdown:h4"         foreground="text"   bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h5"         foreground="text"   bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h6"         foreground="text"   bold="true" weight="bold" scale="1.0"/>

  <!-- ── Inline formatting ── -->
  <style name="qirtas_markdown:bold"        foreground="text"  bold="true" weight="bold"/>
  <style name="qirtas_markdown:italic"      foreground="red"   italic="true"/>
  <style name="qirtas_markdown:bold-italic" foreground="red"   bold="true" weight="bold" italic="true"/>
  <style name="qirtas_markdown:strikethrough" strikethrough="true" foreground="text-muted"/>
  <style name="qirtas_markdown:inline-code" foreground="green"   background="#1f1f1f"/>

  <!-- ── Block elements ── -->
  <style name="qirtas_markdown:blockquote"  foreground="text-dim"   italic="true"/>
  <style name="qirtas_markdown:list-marker" foreground="red"/>

  <!-- ── Links ── -->
  <style name="qirtas_markdown:link-text"   foreground="blue"/>
  <style name="qirtas_markdown:url"         foreground="blue"   underline="true" italic="true"/>
  <style name="qirtas_markdown:wiki-link"   foreground="blue"   underline="true"/>

  <!-- ── Special ── -->
  <style name="qirtas_markdown:highlight"   background="bg-line" foreground="red" bold="true"/>
  <style name="qirtas_markdown:math"        foreground="green"/>
  <style name="qirtas_markdown:comment"     foreground="text-muted" italic="true"/>

  <!-- ── Compatibility aliases ── -->
  <style name="markdown:header"           foreground="red"   bold="true"/>
  <style name="markdown:h1"              foreground="red"    bold="true"  scale="1.5"/>
  <style name="markdown:h2"              foreground="text"   bold="true"  scale="1.3"/>
  <style name="markdown:h3"              foreground="text"   bold="true"/>
  <style name="markdown:h4"              foreground="text"   bold="true"/>
  <style name="markdown:h5"              foreground="text"   bold="true"/>
  <style name="markdown:h6"              foreground="text"   bold="true"/>
  <style name="markdown:bold"            foreground="text"  bold="true"/>
  <style name="markdown:italic"          foreground="red"   italic="true"/>
  <style name="markdown:strikethrough"   strikethrough="true" foreground="text-muted"/>
  <style name="markdown:inline-code"     foreground="green"/>
  <style name="markdown:code"            foreground="green"   background="#1f1f1f"/>
  <style name="markdown:link-text"       foreground="blue"/>
  <style name="markdown:url"             foreground="blue"   underline="true"/>
  <style name="markdown:blockquote-line" foreground="text-dim"   italic="true"/>
  <style name="markdown:list-marker"     foreground="red"/>
</style-scheme>
