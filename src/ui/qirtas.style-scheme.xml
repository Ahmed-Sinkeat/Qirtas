<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="qirtas" _name="Qirtas Ink" version="1.0">
  <author>Qirtas Team</author>
  <description>Qirtas Ink style scheme (Paper &amp; Ink contrast)</description>

  <!-- ── Palette ── -->
  <color name="ink"        value="#2a2722"/>
  <color name="ink-muted"  value="#4a4537"/>
  <color name="ink-faint"  value="#76705f"/>
  <color name="bg"         value="#faf7f0"/>
  <color name="bg-line"    value="#f1ece0"/>
  <color name="selection"  value="#dfe6f1"/>
  <color name="indigo"     value="#213a63"/>

  <!-- ── Heading / formatting accents (illuminated-manuscript rubrication) ── -->
  <color name="rubric"     value="#8a3324"/>
  <color name="pine"       value="#2f5d46"/>
  <color name="plum"       value="#5b3a6e"/>
  <color name="amber"      value="#8a5a1e"/>
  <color name="quote-fg"   value="#0c8f7a"/>   <!-- neon teal — vivid against warm paper -->
  <color name="quote-bg"   value="#e2f4ef"/>
  <color name="italic-fg"  value="#7c3aed"/>   <!-- vivid violet for emphasis -->

  <!-- ── Editor base ── -->
  <style name="text"               foreground="ink"     background="bg"/>
  <style name="selection"          background="selection"/>
  <style name="current-line"       background="bg-line"/>
  <style name="line-numbers"       foreground="ink-faint" background="bg"/>
  <style name="current-line-number" foreground="ink"      bold="true"/>
  <style name="search-match"       background="ink"      foreground="bg"/>
  <style name="bracket-match"      foreground="ink"     bold="true"/>

  <!-- ── def: base styles ── -->
  <style name="def:heading"              foreground="ink"   bold="true"/>
  <style name="def:emphasis"             italic="true"/>
  <style name="def:strong-emphasis"      foreground="ink"  bold="true"/>
  <style name="def:inline-code"          foreground="ink-muted"/>
  <style name="def:preformatted-section" foreground="ink-muted"/>
  <style name="def:comment"             foreground="ink-faint" italic="true"/>
  <style name="def:string"              foreground="ink-muted"/>
  <style name="def:net-address"         foreground="indigo"   underline="true"/>
  <style name="def:link-destination"    foreground="indigo"   underline="true"/>
  <style name="def:link-text"           foreground="ink"/>
  <style name="def:list-marker"         foreground="ink-muted"/>
  <style name="def:shebang"             foreground="ink-faint"   italic="true"/>
  <style name="def:special-char"        foreground="ink"/>
  <style name="def:note"                foreground="ink"            bold="true"/>

  <!-- ── Headings by level (rubricated — each level its own ink) ── -->
  <style name="qirtas_markdown:h1"         foreground="rubric" bold="true" weight="bold" scale="1.5"/>
  <style name="qirtas_markdown:h2"         foreground="pine"   bold="true" weight="bold" scale="1.3"/>
  <style name="qirtas_markdown:h3"         foreground="plum"   bold="true" weight="bold" scale="1.15"/>
  <style name="qirtas_markdown:h4"         foreground="amber"  bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h5"         foreground="ink-muted" bold="true" weight="bold" scale="1.0"/>
  <style name="qirtas_markdown:h6"         foreground="ink-faint" bold="true" weight="bold" scale="1.0"/>

  <!-- ── Inline formatting ── -->
  <style name="qirtas_markdown:bold"        foreground="ink"  bold="true" weight="bold"/>
  <style name="qirtas_markdown:italic"      foreground="italic-fg"   italic="true"/>
  <style name="qirtas_markdown:bold-italic" foreground="rubric"   bold="true" weight="bold" italic="true"/>
  <style name="qirtas_markdown:strikethrough" strikethrough="true" foreground="ink-faint"/>
  <style name="qirtas_markdown:inline-code" foreground="pine"   background="selection"/>

  <!-- ── Block elements ──
       Quote gets a tinted slate background, distinct from the rubric
       headings and ink body text, like a marginal annotation. -->
  <style name="qirtas_markdown:blockquote"  foreground="quote-fg" background="quote-bg" italic="true" bold="true"/>
  <style name="qirtas_markdown:list-marker" foreground="amber"/>

  <!-- ── Links ── -->
  <style name="qirtas_markdown:link-text"   foreground="ink"/>
  <style name="qirtas_markdown:url"         foreground="indigo"   underline="true" italic="true"/>
  <style name="qirtas_markdown:wiki-link"   foreground="indigo" underline="true"/>

  <!-- ── Special ── -->
  <style name="qirtas_markdown:highlight"   background="selection" foreground="ink"/>
  <style name="qirtas_markdown:math"        foreground="ink-muted"/>
  <style name="qirtas_markdown:comment"     foreground="ink-faint" italic="true"/>

  <!-- ── Compatibility aliases ── -->
  <style name="markdown:header"           foreground="rubric" bold="true"/>
  <style name="markdown:h1"              foreground="rubric" bold="true"  scale="1.5"/>
  <style name="markdown:h2"              foreground="pine"   bold="true"  scale="1.3"/>
  <style name="markdown:h3"              foreground="plum"   bold="true"/>
  <style name="markdown:h4"              foreground="amber"  bold="true"/>
  <style name="markdown:h5"              foreground="ink-muted" bold="true"/>
  <style name="markdown:h6"              foreground="ink-faint" bold="true"/>
  <style name="markdown:bold"            foreground="ink"  bold="true"/>
  <style name="markdown:italic"          foreground="italic-fg" italic="true"/>
  <style name="markdown:strikethrough"   strikethrough="true" foreground="ink-faint"/>
  <style name="markdown:inline-code"     foreground="pine"/>
  <style name="markdown:code"            foreground="pine"   background="selection"/>
  <style name="markdown:link-text"       foreground="ink"/>
  <style name="markdown:url"             foreground="indigo"   underline="true"/>
  <style name="markdown:blockquote-line" foreground="quote-fg"   background="quote-bg" italic="true" bold="true"/>
  <style name="markdown:list-marker"     foreground="amber"/>
</style-scheme>
