.zig-cache/
zig-out/
*.db
*.png
*.jpg
!src/ui/icons/**/*.png
# Calligraphy package icon: a non-regenerable source asset that packaging/PKGBUILD
# and the AppImage build both consume. Must live in the repo.
!packaging/appimage/qirtas-package-icon.png
# README screenshots
!assets/screenshots/*.png
*.bak
*.step*
*.before_*
test_run.log
crash_run.log
log.txt
test_*.md
2026-*-this-session-*.txt

# Session artifacts the app writes into the repo when opened as a vault
# (real fix = external-files/vault separation)
capture.syscap
*.syscap
untitled.md
/*.md.original.md
/شرح*.md

# Scratch files app/dev wrote into the tree (untracked, kept on disk)
src/english.txt
src/sa.md
src/test.md
src/Wiki link.md
src/ىى.md

# Stale rescue copies / leftover stubs swept up during clobber cleanup
/_archive/

# Arch packaging build artifacts (makepkg)
packaging/src/
packaging/pkg/
packaging/*.pkg.tar.zst
packaging/*.pkg.tar.zst.sig

# AppImage build artifacts
packaging/appimage/build/
packaging/appimage/*.AppImage

# Flatpak build artifacts
packaging/build-dir/
packaging/.flatpak-builder/

# Dev logs / scratch (regenerable; some were committed by accident — now untracked)
*.log
gdb_commands.txt

# Release outputs (source tarball, built package, AppImage)
dist/
